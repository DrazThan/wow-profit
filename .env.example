# TSM API — get your key at https://id.tradeskillmaster.com/realms/app/account
TSM_API_KEY=your_tsm_api_key_here
TSM_AUTH_URL=https://auth.tradeskillmaster.com/oauth2/token
TSM_REALM_API_URL=https://realm-api.tradeskillmaster.com
TSM_PRICING_API_URL=https://pricing-api.tradeskillmaster.com

# NexusHub
NEXUSHUB_BASE_URL=https://api.nexushub.co/wow-classic/v1

# App defaults
DEFAULT_REALM=faerlina
DEFAULT_FACTION=horde
DEFAULT_REGION=us

# Database — overridden in docker-compose but needed for local dev
DATABASE_URL=postgresql+asyncpg://ahtracker:ahtracker@localhost:5432/ah_tracker

# Redis — optional, falls back to in-memory TTL cache if not set
REDIS_URL=redis://localhost:6379
